Table h_baz_captacion_cliente [headercolor: #3498db] {
  CaptacionClienteHashKey string [pk, Note: 'Llave Hash que proporciona una identificacion unica del hub']
  LoadDate bigint [Note: 'Fecha y hora en la que el registro fue cargado en DV']
  RecordSource string [Note: 'Identificador de la fuente original de los datos']
  SystemSource string [Note: 'Sistema fuente tecnico que genero o entrego el registro']
  Empresa string
  ClienteID string [Note: 'BK']
  TipoCliente string
  Fuente string
  FcUsuarioCreacion string [Note: 'Usuario que proceso la ingesta del registro']
  FdFechaCreacion bigint [Note: 'Fecha en la que se proceso la ingesta del registro']
  FiFecha int [Note: 'Particion diaria YYYYMMDD']
  Note: 'HUB | h_baz_captacion_cliente. HashKey: sha2(num_cus,512). RAW: rd_baz_bdclientes.rd_fin_clientepf, rd_baz_bdclientes.rd_pedt001_cifrada, rd_baz_bdclientes.rd_pedt002_cifrada, rd_baz_bdclientes.rd_pedt054_cifrada'
}

